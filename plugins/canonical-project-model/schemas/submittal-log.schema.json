{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "submittal-log.schema.json",
  "title": "Section — Submittal Register",
  "description": "The submittal register seeded at project start-up: every required submittal by spec section, its type, and any stated lead time / required-by date. Built from the spec's submittal requirements (Division 01 33 00 and per-section 'Submittals' articles). Whether a submittal complies is the submittal-review skill's job; this section structures the register.",
  "type": "object",
  "required": ["section", "entries"],
  "properties": {
    "section": { "type": "string", "const": "submittal_log" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["submittal_id", "description"],
        "properties": {
          "submittal_id": { "type": "string", "description": "Stable id, e.g. 'SUB-0951-01'." },
          "spec_section": { "type": "string", "description": "MasterFormat section requiring the submittal." },
          "csi": { "$ref": "common.defs.schema.json#/$defs/csi_ref" },
          "description": { "type": "string" },
          "submittal_type": { "type": "string", "enum": ["product_data", "shop_drawing", "sample", "mockup", "certificate", "test_report", "om_manual", "warranty", "schedule", "other", "unknown"] },
          "scope_item_id": { "type": "string" },
          "responsible_party": { "type": "string", "description": "Trade/sub responsible (party_id or name) when assignable." },
          "lead_time": { "type": "string", "description": "Stated procurement/fabrication lead time, verbatim." },
          "required_by_date": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["required", "submitted", "under_review", "approved", "approved_as_noted", "revise_resubmit", "unknown"] },
          "provenance": { "$ref": "common.defs.schema.json#/$defs/provenance" }
        }
      }
    }
  }
}
